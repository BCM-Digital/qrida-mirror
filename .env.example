# Copy this file to .env and update values for your environment

# Database settings
DB_DATABASE=qrida
DB_HOST=db
DB_USERNAME=root
DB_PASSWORD=my-secret-pw
DB_PORT=3306

# AWS settings
AWS_REGION=ap-southeast-2

# SMTP settings (if using SMTP/SES)
SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# EFS mount paths
EFS_LOCAL_PATH=/path/to/local/efs
EFS_DEV_PATH=/mnt/dev/efs
EFS_STAGE_PATH=/mnt/stage/efs
EFS_PROD_PATH=/mnt/prod/efs
