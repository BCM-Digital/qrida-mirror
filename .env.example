# Copy this file to .env and update values for your environment

# Database settings
DB_DATABASE=qrida
DB_HOST=db
DB_USERNAME=root
DB_PASSWORD=my-secret-pw
DB_PORT=3306

# AWS settings
AWS_REGION=ap-southeast-2

# EFS mount paths for each environment
EFS_LOCAL=/path/to/local/efs
EFS_DEV=user@dev-host:/mnt/efs
EFS_STAGE=user@stage-host:/mnt/efs
EFS_PROD=user@prod-host:/mnt/efs
# Optional SSH proxy (e.g., bastion host)
EFS_SSH_PROXY=user@bastion-host

# SMTP settings (if using SMTP/SES)
SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
