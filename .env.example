# Copy this file to .env and update values for your environment

# Database settings
DB_DATABASE=qrida
DB_HOST=db
DB_USERNAME=root
DB_PASSWORD=my-secret-pw
DB_PORT=3306

# AWS settings
AWS_REGION=ap-southeast-2

# EFS mounts
EFS_LOCAL_PATH=/mnt/efs
EFS_LOCAL_HOST=localhost
EFS_LOCAL_USER=

EFS_DEV_PATH=/mnt/efs
EFS_DEV_HOST=dev.example.internal
EFS_DEV_USER=ec2-user

EFS_STAGE_PATH=/mnt/efs
EFS_STAGE_HOST=stage.example.internal
EFS_STAGE_USER=ec2-user

EFS_PROD_PATH=/mnt/efs
EFS_PROD_HOST=prod.example.internal
EFS_PROD_USER=ec2-user

# Optional SSH proxy host
SSH_PROXY=

# SMTP settings (if using SMTP/SES)
SMTP_HOST=email-smtp.ap-southeast-2.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
