<!-- field__paragraph__field_faqs__faq_item__faqs.html.twig -->
{% for item in items %}
  <div class="accordion-item">
    <h2 class="accordion-header m-0" id="heading{{ item.content['#node'].nid.value }}">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ item.content['#node'].nid.value }}" aria-expanded="false" aria-controls="collapse{{ item.content['#node'].nid.value }}">
        {{ item.content['#node'].title.value }}
      </button>
    </h2>
    <div id="collapse{{ item.content['#node'].nid.value }}" class="accordion-collapse collapse" aria-labelledby="heading{{ item.content['#node'].nid.value }}">
      <div class="accordion-body">
        {{ item.content['#node'].body.value | raw }}
      </div>
    </div>
  </div>
{% endfor %}
