<!-- paragraph__text_and_cards__default.html.twig -->
{% block paragraph %}
  {% block content %}
    {% if content.field_text_cards__image[0]['#media'] %}
      <div class="paragraph paragraph-text-cards" style="background-image: linear-gradient(90deg, rgba(48, 114, 177, 0.6) 0%, rgba(170, 122, 50, 1) 100%), url('{{ file_url(content.field_text_cards__image[0]['#media'].field_media_image.entity.uri.value) }}');">
    {% else %}
      <div class="paragraph paragraph-text-cards" style="background-color: #EEEEEE;">
    {% endif %}

      <div class="container">
        <div class="row">
          <div class="col-12">
            {{ content.field_text_cards__text[0]['#text'] | raw }}
          </div>
        </div>

        {% if content.field_text_cards__cards['#items'] %}
          <div class="row justify-content-center mt-3">
            {% for item in content.field_text_cards__cards['#items'] %}
              <div class="col-12 col-lg-3 mb-3">
                <div class="card">
                  {{ item.value | raw }}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  {% endblock %}
{% endblock %}
