<!-- templates/page__search.html.twig -->
<div id="page-wrapper">
  <div id="page" data-node-id="{{ node.id }}">
    {% if page.top_header %}
      {% include '/themes/custom/govcms_bartik/inc/top-header.html.twig' %}
    {% endif %}

    {% if page.primary_menu %}
      {% include '/themes/custom/govcms_bartik/inc/primary-menu.html.twig' %}
    {% endif %}

    {% if page.alerts %}
      {% include '/themes/custom/govcms_bartik/inc/page-alerts.html.twig' %}
    {% endif %}

    {% if page.content %}
      <div id="main-wrapper" class="layout-main-wrapper layout-container clearfix">
        <main id="content" class="column main-content" role="main">
          <section class="section">
            <div class="container py-5">
              <div class="row">
                <div class="col-12">
                  {{ drupal_breadcrumb() }}
                </div>
              </div>

              <div class="row">
                <div class="col-12">
                  <a id="main-content" tabindex="-1"></a>
                  {{ page.content }}
                </div>
              </div>
            </div>
          </section>
        </main>
      </div>
    {% endif %}

    {% if page.footer_middle %}
      {% include '/themes/custom/govcms_bartik/inc/footer-middle.html.twig' %}
    {% endif %}

    {% if page.footer_bottom %}
      {% include '/themes/custom/govcms_bartik/inc/footer-bottom.html.twig' %}
    {% endif %}
  </div>
</div>
